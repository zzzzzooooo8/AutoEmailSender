# 默认不需要改，后端会自动使用项目根目录下的 data/auto_email_sender.db
DATABASE_URL=sqlite+aiosqlite:///D:/path/to/AutoEmailSender/data/auto_email_sender.db

# 本地后台 worker 轮询周期
DRAFT_WORKER_INTERVAL_SECONDS=10
DISPATCHER_INTERVAL_SECONDS=30
IMAP_POLL_INTERVAL_SECONDS=300

# 真实外部服务超时与回信回溯窗口
LLM_REQUEST_TIMEOUT_SECONDS=90
SMTP_SEND_TIMEOUT_SECONDS=30
IMAP_LOOKBACK_HOURS=72

# 测试环境可以关闭后台 worker，避免自动消费
ENABLE_BACKGROUND_WORKERS=true
